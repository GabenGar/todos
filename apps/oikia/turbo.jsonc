{
  "$schema": "https://turborepo.com/schema.v2.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**",
        "public/**",
        "schema/**",
        "scripts/**",
        "localization/**",
        "backend/**"
      ],
      "outputs": ["build/**"]
    },
    "start": {
      "persistent": true,
      "cache": false
    },
    "develop-database-purge": {
      "cache": false
    }
  }
}
