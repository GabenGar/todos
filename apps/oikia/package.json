{
  "name": "oikia",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "start": "node ./scripts/start.js",
    "dev": "node ./scripts/dev.js",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --formatter-enabled=false --linter-enabled=false --write && react-router typegen && tsc --build",
    "develop-database-purge": "node scripts/develop/database/purge.mjs"
  },
  "imports": {
    "#localization/*": "./localization/*.json",
    "#environment": "./src/environment/index.ts",
    "#environment/*": "./src/environment/*/index.ts",
    "#lib/*": "./src/lib/*/index.ts",
    "#hooks": "./src/hooks/index.ts",
    "#components/*": "./src/components/*/index.ts",
    "#entities/*": "./src/entities/*/index.ts",
    "#database": "./src/.server/database/index.ts",
    "#database/*": "./src/.server/database/*/index.ts",
    "#server/*": "./src/.server/*/index.ts",
    "#client/*": "./src/.client/*/index.ts"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@exodus/schemasafe": "^1.3.0",
    "@react-router/express": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@react-router/serve": "^7.13.1",
    "@repo/ui": "*",
    "bcp-47": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "i18next": "25.8.18",
    "isbot": "^5.1.35",
    "iso-639-1": "^3.1.5",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.18.0",
    "pg-promise": "^12.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.8",
    "react-router": "^7.13.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@react-router/dev": "^7.13.1",
    "@repo/biome-config": "*",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.16.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
