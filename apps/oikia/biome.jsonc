{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "root": false,
  "extends": ["@repo/biome-config/base", "@repo/biome-config/react"],
  "files": {
    "includes": ["**", "!!**/build", "!**/.react-router", "!**/.vite-env.d.ts"]
  },
  "linter": {
    "rules": {
      "correctness": {
        // server endpoints feature a lot of `req`/`res` arguments
        "noUnusedFunctionParameters": "off"
      }
    }
  }
}
