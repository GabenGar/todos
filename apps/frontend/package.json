{
  "name": "frontend",
  "version": "0.39.0",
  "description": "NextJS frontend for todo list.",
  "private": true,
  "scripts": {
    "build-pages": "next build --webpack",
    "build-codegen": "cd ./codegen/generators && npm run build",
    "build-workers": "webpack --config webpack.prod.mjs",
    "start": "serve ./out -p 9001 --no-clipboard --no-port-switching",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --formatter-enabled=false --linter-enabled=false --write && next typegen && tsc --noEmit",
    "dev": "next dev --port 8001 --webpack",
    "dev-workers": "webpack --config webpack.dev.mjs --watch",
    "codegen": "npm run build-codegen && node ./scripts/codegen.mjs && biome format --write ./codegen/output"
  },
  "imports": {
    "#translation/*": "./translation/*",
    "#environment": "./src/environment/index.ts",
    "#environment/*": "./src/environment/*/index.ts",
    "#pages/types": "./src/app/types.ts",
    "#lib/*": "./src/lib/*/index.ts",
    "#server": "./src/server/index.ts",
    "#server/*": "./src/server/*/index.ts",
    "#store/*": "./src/browser/store/*/index.ts",
    "#browser/*": "./src/browser/*/index.ts",
    "#hooks": "./src/hooks/index.ts",
    "#components": "./src/components/index.ts",
    "#components/types": "./src/components/types.ts",
    "#components/*": "./src/components/*/index.ts",
    "#entities/*": "./src/entities/*/index.ts",
    "#types": "./src/types.ts",
    "#json-schema/*": "./codegen/output/json-schema/*/index.ts"
  },
  "dependencies": {
    "@hyperjump/json-schema": "^1.17.4",
    "@next/env": "16.1.6",
    "@repo/nodejs": "*",
    "@repo/ui": "*",
    "@repo/webpack": "*",
    "ajv": "^8.18.0",
    "bcp-47": "^2.1.0",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "i18next": "25.8.14",
    "i18next-resources-to-backend": "^1.2.1",
    "iso-639-1": "^3.1.5",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "16.5.5",
    "stringify-object": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@repo/biome-config": "*",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/stringify-object": "^4.0.5",
    "sass": "^1.97.3",
    "serve": "^14.2.5",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  }
}
