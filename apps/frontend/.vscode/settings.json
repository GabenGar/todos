{
  "dotenv.enableSecretpeeking": false,
  "files.associations": {
    ".env.*": "dotenv"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[scss]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "json.schemas": [
    {
      "fileMatch": ["**/*.schema.json"],
      "url": "https://json-schema.org/draft/2020-12/schema"
    },
    {
      "fileMatch": ["public/manifest.json"],
      "url": "./schema/manifest.schema.json"
    }
  ]
}
