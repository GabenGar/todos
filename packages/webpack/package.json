{
  "name": "@repo/webpack",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check": "biome check --formatter-enabled=false --linter-enabled=false --write && tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./api/index.ts",
      "default": "./dist/api/index.js"
    }
  },
  "imports": {
    "#*": {
      "types": "./src/*/index.ts",
      "default": "./src/*/index.js"
    }
  },
  "dependencies": {
    "@repo/nodejs": "*",
    "schema-utils": "^4.3.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@repo/biome-config": "*",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2"
  }
}
