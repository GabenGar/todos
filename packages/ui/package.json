{
  "name": "@repo/ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --formatter-enabled=false --linter-enabled=false --write && tsc --noEmit"
  },
  "exports": {
    "./translation/*": "./translation/*",
    "./styles/global": "./src/styles/global.scss",
    "./styles/global/extension/options": "./src/styles/global/extension/options.scss",
    "./styles/global/extension/popup": "./src/styles/global/extension/popup.scss",
    "./styles/global/nextjs/pages": "./src/styles/global/nextjs/pages.scss",
    "./styles/variables": "./src/styles/variables.scss",
    "./styles/sass/variables": "./src/styles/sass/variables.scss",
    "./styles/sass/mixins": "./src/styles/sass/mixins.scss",
    "./*": "./src/*/index.ts"
  },
  "imports": {
    "#*": "./src/*/index.ts"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "bcp-47": "^2.1.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^25.8.13",
    "iso-639-1": "^3.1.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@repo/biome-config": "*",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "^5.9.3"
  }
}
