{
  "$schema": "https://v2-8-10.turborepo.dev/schema.json",
  "tasks": {
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "build": {
      "dependsOn": ["^build"]
    },
    "codegen": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {},
    "prep": {},
    "start": {},
    "validate": {}
  }
}
